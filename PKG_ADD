pkg_dir = fileparts(mfilename('fullpath'));
% Octave needs the implementation folders for unqualified superclass
% references inside the current v1.x compatibility layer.  BeamFactory
% dynamically adds pkg_dir as +paraxial parent before resolving canonical
% package classes.
addpath(fullfile(pkg_dir, '+paraxial', '+beams'));
addpath(fullfile(pkg_dir, '+paraxial', '+parameters'));
addpath(fullfile(pkg_dir, '+paraxial', '+computation'));
addpath(fullfile(pkg_dir, '+paraxial', '+propagation', '+field'));
addpath(fullfile(pkg_dir, '+paraxial', '+propagation', '+rays'));
addpath(fullfile(pkg_dir, '+paraxial', '+visualization'));
addpath(fullfile(pkg_dir, 'ParaxialBeams'));
